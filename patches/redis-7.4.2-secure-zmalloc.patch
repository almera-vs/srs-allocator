diff --git a/src/Makefile b/src/Makefile
index cc84d09..64a5b35 100644
--- a/src/Makefile
+++ b/src/Makefile
@@ -101,6 +101,10 @@ ifeq ($(USE_JEMALLOC),no)
 	MALLOC=libc
 endif
 
+ifeq ($(USE_SECURE_SPARK_ALLOCATOR),yes)
+	MALLOC=spark_secure
+endif
+
 ifdef SANITIZER
 ifeq ($(SANITIZER),address)
 	MALLOC=libc
@@ -280,6 +284,14 @@ ifeq ($(MALLOC),jemalloc)
 	FINAL_LIBS := ../deps/jemalloc/lib/libjemalloc.a $(FINAL_LIBS)
 endif
 
+ifeq ($(MALLOC),spark_secure)
+	FINAL_CFLAGS+= -DUSE_SECURE_SPARK_ALLOCATOR
+	SECURE_ALLOCATOR_LIB_DIR?=../build/lib
+	FINAL_LDFLAGS+= -L$(SECURE_ALLOCATOR_LIB_DIR) -Wl,-rpath,$(abspath $(SECURE_ALLOCATOR_LIB_DIR))
+	GNAT_RUNTIME_LIB_DIR?=
+	FINAL_LIBS := -lsecure_allocator -L$(GNAT_RUNTIME_LIB_DIR) -lgnarl -lgnat -lSystem $(FINAL_LIBS)
+endif
+
 # LIBSSL & LIBCRYPTO
 LIBSSL_LIBS=
 LIBSSL_PKGCONFIG := $(shell $(PKG_CONFIG) --exists libssl && echo $$?)
